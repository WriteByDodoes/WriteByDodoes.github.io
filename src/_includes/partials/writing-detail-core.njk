{% set detailDefaultCategory = defaultCategory or 'notes' %}
{% set detailRelated = relatedCollection or [] %}
{% set detailContentWithHeadings = content | addHeadingIds %}
{% set detailTocItems = detailContentWithHeadings | extractHeadings %}
{% set detailHasShell = showPostToc %}

{% if detailHasShell %}
<div class="post-detail-rails{% if showPostToc %} post-detail-toc-only{% endif %}">
  <div class="post-detail-main">
{% endif %}

  <article class="writing-note">
    <header class="writing-header">
      <div class="writing-kicker">{{ category or detailDefaultCategory }}</div>
      <h1 class="writing-title">{{ title }}</h1>
      <div class="writing-meta">
        {% if writingDateFormat %}
        <span class="writing-date">{{ date | readableDate(writingDateFormat) }}</span>
        {% else %}
        <span class="writing-date">{{ date | readableDate }}</span>
        {% endif %}
        <span class="writing-author">{% if showAuthorByPrefix !== false %}by {% endif %}{{ detailAuthorLabel or site.author }}</span>
      </div>
    </header>

    <div class="writing-content prose">
      {{ detailContentWithHeadings | safe }}
    </div>
  </article>

  {% set relatedPosts = detailRelated | hybridRelatedPosts(page.url, 4) %}
  <section class="related-posts writing-related-posts">
    <div class="section-header">
      <h2>이 글 다음으로 읽기</h2>
    </div>
    {% if relatedPosts.length > 0 %}
    <ol class="writing-related-list">
      {% for item in relatedPosts %}
        <li>
          <a class="writing-related-link" href="{{ item.post.url | url }}">
            <span class="writing-related-body">
              <span class="writing-related-title">{{ item.post.data.title }}</span>
              <span class="writing-related-meta">{{ item.post.data.category | default(detailDefaultCategory) }} · {{ item.post.date | readableDate }}</span>
            </span>
          </a>
        </li>
      {% endfor %}
    </ol>
    {% else %}
    <p class="muted">아직 추천할 글이 없습니다.</p>
    {% endif %}
  </section>

{% if detailHasShell %}
  </div>

  {% if detailTocItems.length > 0 %}
  <aside class="post-toc" aria-label="글 목차">
    <nav class="post-toc-inner">
      <div class="post-toc-rail" aria-hidden="true">
        {% for heading in detailTocItems %}
        <span class="post-toc-rail-marker post-toc-rail-level-{{ heading.level }}" data-toc-target="{{ heading.id }}"></span>
        {% endfor %}
      </div>
      <div class="post-toc-flyout">
        {% for heading in detailTocItems %}
        <div class="post-toc-item post-toc-level-{{ heading.level }}">
          <a class="post-toc-link" href="#{{ heading.id }}">{{ heading.text }}</a>
        </div>
        {% endfor %}
      </div>
    </nav>
  </aside>
  {% endif %}
</div>
{% endif %}
