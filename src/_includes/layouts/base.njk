{% set newestPost = collections.writing | first %}
<!doctype html>
<html lang="ko">
  <head>
    {% set pageTitle = title or '' %}
    {% set docTitle = '블로그' %}
    {% if pageTitle %}
      {% set docTitle = pageTitle + ' · ' + site.title %}
    {% else %}
      {% set docTitle = site.title %}
    {% endif %}
    {% set contentSummary = content | firstParagraphText(160) %}
    {% set metaDescription = excerpt or description or contentSummary or site.description %}
    {% set canonicalHref = canonicalUrl or (site.url + (page.url | url)) %}
    {% set ogType = 'article' if layout == 'layouts/writing.njk' else 'website' %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com; img-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'"
    />
    <title>{{ docTitle }}</title>
    <meta name="description" content="{{ metaDescription }}" />
    <link rel="canonical" href="{{ canonicalHref }}" />
    <meta property="og:title" content="{{ docTitle }}" />
    <meta property="og:description" content="{{ metaDescription }}" />
    <meta property="og:url" content="{{ canonicalHref }}" />
    <meta property="og:type" content="{{ ogType }}" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="{{ docTitle }}" />
    <meta name="twitter:description" content="{{ metaDescription }}" />
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/icons/favicon-32x32.png' | url }}" />
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/icons/favicon-16x16.png' | url }}" />
    <link rel="shortcut icon" href="{{ '/assets/icons/favicon-512x512.png' | url }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/icons/favicon-180x180.png' | url }}" />
    <meta name="msapplication-TileImage" content="{{ '/assets/icons/favicon-192x192.png' | url }}" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,700&family=Noto+Serif+KR:wght@400;500;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="{{ '/styles/main.css' | url }}" />
  </head>
  <body class="theme-dodoes">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <aside class="sidebar-drawer" id="sidebar-drawer">
      <button class="drawer-close" id="drawer-close" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <nav class="drawer-nav">
        <a href="{{ '/' | url }}">홈</a>
        <a href="{{ '/about/' | url }}">소개</a>
        <a href="{{ '/posts/' | url }}">글</a>
      </nav>
    </aside>

    <header class="site-header" id="site-header">
      <div class="header-inner">
        <div class="brand">
          <a class="brand-home" href="{{ '/' | url }}">
            <img class="brand-mark" src="{{ '/assets/icons/icon.png' | url }}" alt="" width="36" height="36" decoding="async" />
            <span class="brand-copy">
              <span class="brand-title">{{ site.title }}</span>
            </span>
          </a>
        </div>

        <nav class="nav">
          <a href="{{ '/' | url }}" {% if page.url == '/' %}class="active"{% endif %}>홈</a>
          <a href="{{ '/about/' | url }}" {% if page.url.startsWith('/about/') %}class="active"{% endif %}>소개</a>
          <a href="{{ '/posts/' | url }}" {% if page.url.startsWith('/posts/') %}class="active"{% endif %}>글</a>
        </nav>

        <button class="menu-btn" id="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="sidebar-drawer">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </header>

    <div class="site-wrap">
      <main class="site-main">{{ content | safe }}</main>

      <footer class="footer footer-minimal">
        {% if newestPost %}
          {% set footerYear = newestPost.date | readableDate('yyyy') %}
        {% else %}
          {% set footerYear = '' %}
        {% endif %}
        <div class="footer-meta">
          <span>© {{ site.author }}{% if footerYear %} {{ footerYear }}{% endif %}</span>
          <span>Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a></span>
        </div>
      </footer>
    </div>

    <script src="{{ '/assets/base-ui.js' | url }}" defer></script>
  </body>
</html>
